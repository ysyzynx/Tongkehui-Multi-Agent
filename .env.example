# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Database
DB_URL=sqlite:///./tongkehui.db

# LLM
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo
VISION_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# DeepSearch (optional)
DEEPSEARCH_API_KEY=
DEEPSEARCH_API_BASE=
DEEPSEARCH_MODEL=
DEEPSEARCH_ENABLE_SEARCH=true
DEEPSEARCH_SELF_CHECK=true

# Volcengine image generation (optional)
VOLCENGINE_API_KEY=
VOLCENGINE_IMAGE_MODEL=doubao-seedream-5-0-260128

# SerpAPI (optional)
SERPAPI_API_KEY=

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:5177,*
